import java.util.Scanner;

public class SistemaDesconto {

    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);

        System.out.println("Digite o valor da compra: ");
        double valorCompra = scanner.nextDouble();

        System.out.println("Forma de pagamento:");
        System.out.println("1 - À vista (10% de desconto)");
        System.out.println("2 - Cartão (5% de desconto)");
        System.out.println("3 - Pix (15% de desconto)");
        System.out.println("4 - Outros (sem desconto)");

        int formaPagamento = scanner.nextInt();

        double desconto = calcularDesconto(valorCompra, formaPagamento);
        double valorFinal = valorCompra - desconto;

        mostrarResumo(valorCompra, desconto, valorFinal);

        scanner.close();
    }

    public static double calcularDesconto(double valor, int formaPagamento) {

        if (formaPagamento == 1) {
            return valor * 0.10;
        } else if (formaPagamento == 2) {
            return valor * 0.05;
        } else if (formaPagamento == 3) {
            return valor * 0.15; // NOVO DESCONTO PIX
        } else {
            return 0;
        }
    }

    public static void mostrarResumo(double valor, double desconto, double total) {

        System.out.println("\n===== RESUMO DA COMPRA =====");
        System.out.printf("Valor original: R$ %.2f%n", valor);
        System.out.printf("Desconto: R$ %.2f%n", desconto);
        System.out.printf("Valor final: R$ %.2f%n", total);
    }
}
