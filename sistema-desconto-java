package TreinamentosERevisoes;
import java.util.Scanner;


public class Treino1 {

	public static void main(String[] args) {
		
		Scanner scanner = new Scanner(System.in);
		
		
		System.out.println("Digite o nome do cliente: ");
		   String nomecliente = scanner.nextLine();
		   
		System.out.println("Digite o valor da compra: ");
		   double valorcompra = scanner.nextDouble();
  
        System.out.println("Escolha a forma de pagamendo \n Digite 1 para pagamento À vista \n Digite 2 para pagamento por Débito \n Digite 3 para pagamento de crédito");
           int formaPag = scanner.nextInt();

         double desconto;
         double valtotal;
         double valdesconto;
           
        if (formaPag == 1) {
		   desconto = (10.0/100);		   
	}
        
        else if (formaPag == 2) {
           desconto = (5.0/100);         
        }

        else {        	
           desconto = 0;                   	
        }
        
        valdesconto = (valorcompra * desconto);
        valtotal = (valorcompra - valdesconto);
        
        
        System.out.printf("Nome do cliente: %s%n", nomecliente);
        System.out.printf("Valor original: %.2f%n", valorcompra);
        System.out.printf("Valor do desconto: %.2f%n", valdesconto);
        System.out.printf("Valor final: %.2f%n", valtotal);
        
        
        scanner.close();
}
}
